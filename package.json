{
  "name": "cursor-auto-confirm",
  "displayName": "Cursor Auto Confirm",
  "description": "Automatically confirm commands across all terminal tabs with a popup notification",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorAutoConfirm.enable",
        "title": "Enable Auto Confirm"
      },
      {
        "command": "cursorAutoConfirm.disable",
        "title": "Disable Auto Confirm"
      },
      {
        "command": "cursorAutoConfirm.toggle",
        "title": "Toggle Auto Confirm"
      },
      {
        "command": "cursorAutoConfirm.confirmAll",
        "title": "Confirm in All Terminals",
        "icon": "$(check-all)"
      }
    ],
    "keybindings": [
      {
        "command": "cursorAutoConfirm.confirmAll",
        "key": "ctrl+shift+enter",
        "when": "terminalFocus"
      }
    ],
    "configuration": {
      "title": "Cursor Auto Confirm",
      "properties": {
        "cursorAutoConfirm.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic command confirmation"
        },
        "cursorAutoConfirm.delay": {
          "type": "number",
          "default": 500,
          "description": "Delay in milliseconds before auto-confirming (0 = immediate)"
        },
        "cursorAutoConfirm.showNotification": {
          "type": "boolean",
          "default": true,
          "description": "Show notification when auto-confirming commands"
        },
        "cursorAutoConfirm.confirmAllTabs": {
          "type": "boolean",
          "default": true,
          "description": "Auto-confirm in all terminal tabs across all projects"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^18.0.0",
    "typescript": "^4.9.0"
  }
}

